generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  avatarUrl    String?
  role         Role      @default(MEMBER)
  isBanned     Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  articles      Article[]
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  revisions     Revision[]
  clips         Clip[]
  memories      Memory[]
  sessions      Session[]
  userAwards    UserAward[]
  clipAwards    ClipAward[]
  clipFavorites ClipFavorite[]
  uploadQueue   UploadQueue[]

  @@index([email])
}

enum Role {
  MEMBER
  ADMIN
}

model Article {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  imageUrl    String?
  authorId    String
  isDraft     Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  viewCount   Int      @default(0)

  author      User      @relation(fields: [authorId], references: [id])
  tags        Tag[]     @relation("ArticleTags")
  revisions   Revision[]
  likes       Like[]
  memories    Memory[]

  @@index([slug])
  @@index([authorId])
  @@index([createdAt])
  @@index([viewCount])
}

model Revision {
  id          String   @id @default(uuid())
  articleId   String
  authorId    String
  content     String
  editSummary String?
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([articleId])
  @@index([createdAt])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String?
  createdAt   DateTime @default(now())

  @@index([slug])
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  articles  Article[] @relation("ArticleTags")
  clips     Clip[]

  @@index([slug])
}

model Post {
  id           String   @id @default(uuid())
  content      String
  authorId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  images       String[]
  links        String[]

  author   User      @relation(fields: [authorId], references: [id])
  comments Comment[]
  likes    Like[]
  memories Memory[]

  @@index([authorId])
  @@index([createdAt])
  @@index([likeCount])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  postId    String?
  clipId    String?
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isEdited  Boolean  @default(false)

  user    User     @relation(fields: [userId], references: [id])
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  clip    Clip?    @relation(fields: [clipId], references: [id], onDelete: Cascade)
  parent  Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([clipId])
  @@index([userId])
  @@index([createdAt])
}

model Clip {
  id                String       @id @default(uuid())
  discordMessageId  String?      @unique
  discordChannelId  String?
  title             String?
  description       String?
  discordUserId     String?
  discordUserName   String?
  discordUserAvatar String?
  videoUrl          String
  originalUrl       String?
  compressedUrl     String?
  thumbnailUrl      String?
  spriteFrames      String[]     @default([])
  fileSize          Int?
  resolution        String?
  duration          Int?
  category          ClipCategory @default(OTHER)
  createdAt         DateTime     @default(now())
  indexedAt         DateTime     @default(now())
  likeCount         Int          @default(0)
  commentCount      Int          @default(0)
  awardCount        Int          @default(0)
  isApproved        Boolean      @default(true)
  processingStatus  String       @default("completed")

  author   User?     @relation(fields: [authorId], references: [id])
  authorId String?
  comments Comment[]
  likes    Like[]
  tags     Tag[]
  memories Memory[]
  awards   ClipAward[]
  favorites ClipFavorite[]

  @@index([discordMessageId])
  @@index([discordUserId])
  @@index([isApproved])
  @@index([createdAt])
  @@index([processingStatus])
}

enum ClipCategory {
  FUNNY
  EPIC
  FAIL
  TUTORIAL
  OTHER
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  clipId    String?
  articleId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  clip    Clip?    @relation(fields: [clipId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, clipId, articleId])
  @@index([userId])
}

model Memory {
  id               String     @id @default(uuid())
  title            String
  content          String
  type             MemoryType
  relatedArticleId String?
  relatedClipId    String?
  relatedPostId    String?
  featuredBy       String
  featuredAt       DateTime   @default(now())
  eventDate        DateTime
  imageUrl         String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  featuredByUser  User     @relation(fields: [featuredBy], references: [id])
  article         Article? @relation(fields: [relatedArticleId], references: [id])
  clip            Clip?    @relation(fields: [relatedClipId], references: [id])
  post            Post?    @relation(fields: [relatedPostId], references: [id])

  @@index([type])
  @@index([eventDate])
  @@index([featuredAt])
}

enum MemoryType {
  EVENT
  MILESTONE
  HIGHLIGHT
  ANNIVERSARY
  OTHER
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Award {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String?
  category    String
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userAwards  UserAward[]

  @@index([category])
}

model UserAward {
  id        String   @id @default(uuid())
  userId    String
  awardId   String
  awardedAt DateTime @default(now())
  note      String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  award Award @relation(fields: [awardId], references: [id], onDelete: Cascade)

  @@unique([userId, awardId])
  @@index([userId])
  @@index([awardId])
}

model ClipAward {
  id        String   @id @default(uuid())
  clipId    String
  userId    String
  awardType String
  awardedAt DateTime @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clipId, userId, awardType])
  @@index([clipId])
  @@index([userId])
  @@index([awardType])
}

model ClipFavorite {
  id        String   @id @default(uuid())
  clipId    String
  userId    String
  createdAt DateTime @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clipId, userId])
  @@index([clipId])
  @@index([userId])
}

model UploadQueue {
  id           String   @id @default(uuid())
  userId       String
  fileName     String
  fileSize     Int
  r2Key        String?
  status       String   @default("pending")
  progress     Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}
